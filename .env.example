# 必须由已取得中国公共招聘网书面授权的项目设置为 true。
MOHRSS_AUTHORIZED=false

# 可选：星辰自定义插件使用 Service 鉴权时，将此值配置为 Header: X-Plugin-Key。
PLUGIN_API_KEY=replace-with-a-random-secret

# BOSS 数据源登录 Cookie，格式与 `boss login` 文档一致。
BOSS_COOKIES=

# BOSS 账号保护：相同查询优先读取 SQLite 缓存，默认 30 分钟不过期。
# 代码强制最低 60 秒，避免误配为 0 后让 Agent 高频回源。
BOSS_PLUGIN_CACHE_TTL_S=1800

# BOSS 账号保护：所有缓存未命中的 BOSS 请求跨进程至少间隔 10 秒。
# 代码强制最低 5 秒；生产环境建议保持 10 秒或提高到 15~30 秒。
BOSS_PLUGIN_MIN_INTERVAL_S=10

# 中国公共招聘网使用独立缓存与限流命名空间，不与 BOSS 相互影响。
PUBLIC_PLUGIN_CACHE_TTL_S=1800
PUBLIC_PLUGIN_MIN_INTERVAL_S=2

# 可选：使用 OpenAI-compatible LLM 生成“仅用于 SQLite 缓存键”的平台语义别名。
# 默认关闭；模型不会获得招聘平台 Cookie，也不能修改实际发往平台的查询参数。
LLM_SEMANTIC_CACHE_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_SEMANTIC_CONFIDENCE=0.92
LLM_SEMANTIC_ALIAS_TTL_S=604800
LLM_TIMEOUT_S=5

PLUGIN_HOST=0.0.0.0
PLUGIN_PORT=8000